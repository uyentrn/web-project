# Application
NODE_ENV=development
PORT=3000

# PostgreSQL. Use an SSL-enabled managed database URL in production.
DATABASE_URL=postgresql://perfume:change-me@localhost:5432/perfume_store?schema=public
POSTGRES_PASSWORD=change-me

# JWT: use a unique, high-entropy value from a secret manager in production.
JWT_SECRET=replace-with-a-long-random-secret
JWT_ISSUER=perfume-ecommerce-api
JWT_AUDIENCE=perfume-ecommerce-client
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
BCRYPT_ROUNDS=12

# AWS deployment defaults
AWS_REGION=ap-southeast-1
STAGE=dev
